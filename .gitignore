# ============================================================
# 面经 Agent 项目 .gitignore
# ============================================================

# ━━━ 环境与密钥（含 API Key / Token，禁止提交）━━━
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
CREDENTIALS.md
*credentials*
*secrets*
**/secrets/

# ━━━ 后端数据（不提交到仓库）━━━
backend/data/
backend/logs/
backend/*.db
*.db
*.db-journal
*.db-wal

# 根目录遗留数据目录（已迁移至 backend/data，若存在可删除）
memory/
memory_data/
neo4j_data/
xhs_user_data/
qdrant_storage/
test_nowcoder_output/

# 本地参考与思路（不上传）
参考项目/
思路/
微调\llm_logs
# ━━━ 前端构建与依赖 ━━━
node_modules/
frontend/dist/
web/node_modules/
web/dist/
backend/static/dist/

# ━━━ Python ━━━
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# ━━━ 虚拟环境 ━━━
.venv/
venv/
ENV/

# ━━━ IDE 与编辑器 ━━━
.idea/
.vscode/
.claude/
*.swp
*.swo

# ━━━ 调试与临时文件 ━━━
*.log
*.tmp
debug_*.txt
debug_*.html
*_stderr.log
*_stdout.log
uvicorn_*.txt
xhs_link_cache.txt

# 临时脚本和归档
scripts/temp/
docs/archive/

# ━━━ HelloAgents 源码（项目使用 pip 安装的 hello-agents 包）━━━
HelloAgents/
HelloAgents-1.0.0/

# ━━━ 系统文件 ━━━
.DS_Store
Thumbs.db


