# ============================================================
# 面经 Agent 项目环境变量示例
# 复制为 .env 并填入真实配置：cp .env.example .env
# 注意：请勿将 .env 提交到 Git（已加入 .gitignore）
# ============================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. LLM 配置（支持本地/远程切换）
#    LLM_MODE: local（Ollama）或 remote（云端 API）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LLM_MODE=local

# 本地配置（Ollama）
LLM_LOCAL_PROVIDER=ollama
LLM_LOCAL_MODEL=qwen3:4b
LLM_LOCAL_API_KEY=ollama
LLM_LOCAL_BASE_URL=http://localhost:11434/v1
LLM_LOCAL_TIMEOUT=300

# 远程配置（云端 API，如火山引擎、OpenAI、DashScope）
LLM_REMOTE_PROVIDER=volcengine
LLM_REMOTE_MODEL=your_model_id
LLM_REMOTE_API_KEY=your_api_key_here
LLM_REMOTE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_REMOTE_TIMEOUT=300

# 通用
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. 各 Agent 差异化配置（留空则使用全局 LLM 配置）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Knowledge Manager Agent
ARCHITECT_MODE=local
KNOWLEDGE_MANAGER_TEMPERATURE=0.2
KNOWLEDGE_MANAGER_MAX_TOKENS=

# Interviewer Agent（若出现「Request timed out」/「Function Calling调用失败」，可增大 TIMEOUT）
INTERVIEWER_MODE=local
INTERVIEWER_LOCAL_PROVIDER=ollama
INTERVIEWER_LOCAL_MODEL=qwen3:4b
INTERVIEWER_LOCAL_BASE_URL=http://localhost:11434/v1
INTERVIEWER_LOCAL_TIMEOUT=180
INTERVIEWER_REMOTE_PROVIDER=
INTERVIEWER_REMOTE_MODEL=
INTERVIEWER_REMOTE_BASE_URL=
INTERVIEWER_REMOTE_TIMEOUT=
INTERVIEWER_TEMPERATURE=0.5
INTERVIEWER_MAX_TOKENS=
INTERVIEWER_MAX_STEPS=20
INTERVIEWER_TIMEOUT=180

# Miner Agent（题目提取）
MINER_MODE=local
MINER_LOCAL_PROVIDER=ollama
MINER_LOCAL_MODEL=qwen3:4b
MINER_LOCAL_BASE_URL=http://localhost:11434/v1
MINER_LOCAL_TIMEOUT=180
MINER_REMOTE_PROVIDER=
MINER_REMOTE_MODEL=
MINER_REMOTE_BASE_URL=
MINER_REMOTE_TIMEOUT=
MINER_TEMPERATURE=0
MINER_MAX_TOKENS=2048
MINER_MAX_RETRIES=3
CRAWLER_FETCH_MAX_RETRIES=3
CRAWLER_RETRY_DELAY=5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. Embedding（向量化，用于 MemoryTool 语义记忆、Neo4j 向量检索）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 云端（可能欠费 Arrearage）：EMBED_MODEL_TYPE=dashscope
# 本地（免 API Key）：EMBED_MODEL_TYPE=ollama，需先 ollama pull qwen3-embedding:0.6b
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v4
EMBED_API_KEY=your_dashscope_api_key_here
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 本地 Ollama（EMBED_MODEL_TYPE=ollama 时生效）
# EMBED_MODEL_TYPE=ollama
# EMBED_MODEL_NAME=qwen3-embedding:0.6b
# EMBED_OLLAMA_URL=http://localhost:11434

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. Neo4j 知识图谱（本地 Docker: docker compose up -d）
#    管理界面：http://localhost:7474
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. Qdrant 向量数据库（hello-agents MemoryTool）
#    本地：docker compose up -d qdrant → http://localhost:6333
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. 本地存储
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SQLITE_DB_PATH=./backend/data/local_data.db
MEMORY_DATA_DIR=./backend/data/memory
LOG_DIR=./backend/logs
XHS_USER_DATA_DIR=./backend/data/xhs_user_data
LLM_PROMPT_LOG_CSV=./微调/llm_logs/llm_prompt_log.jsonl

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 7. 牛客网爬虫
#    Cookie：浏览器登录牛客 → F12 → Network → 任意请求 → Request Headers → Cookie
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NOWCODER_COOKIE=
NOWCODER_KEYWORDS=agent面经
NOWCODER_MAX_PAGES=2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 8. 小红书爬虫
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

XHS_KEYWORDS=agent面经
XHS_MAX_NOTES_PER_KEYWORD=5
XHS_LOGIN_WAIT_SECONDS=120

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 9. 微调辅助大模型（微调页面生成标注数据）
#    使用 FINETUNE_MODE + FINETUNE_LOCAL_* / FINETUNE_REMOTE_*
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

FINETUNE_MODE=remote
FINETUNE_LOCAL_PROVIDER=
FINETUNE_LOCAL_MODEL=
FINETUNE_LOCAL_BASE_URL=
FINETUNE_LOCAL_TIMEOUT=
FINETUNE_REMOTE_PROVIDER=volcengine
FINETUNE_REMOTE_MODEL=your_model_id
FINETUNE_REMOTE_API_KEY=your_api_key_here
FINETUNE_REMOTE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
FINETUNE_REMOTE_TIMEOUT=180
FINETUNE_LLM_TEMPERATURE=0.2
FINETUNE_LLM_TIMEOUT=180

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 10. 定时调度器
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SCHEDULER_ENABLE_NOWCODER=true
SCHEDULER_NOWCODER_HOURS=2,14
SCHEDULER_ENABLE_XHS=true
SCHEDULER_PROCESS_MINUTE=0
CRAWLER_PROCESS_BATCH_SIZE=100
CRAWLER_RECURSIVE_RETRY_MAX=10

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 11. 对话 Agent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

DEFAULT_USER_ID=default_user
INTERVIEWER_MAX_STEPS=100

# 关闭 HuggingFace symlink 警告
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OCR 配置
#   qwen_vl     — 阿里云百炼（复用 EMBED_API_KEY）
#   claude_vision — Anthropic Claude Vision（需 ANTHROPIC_API_KEY）
#   mcp         — 本地 mcp-image-extractor
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

OCR_METHOD=qwen_vl
# OCR_MODEL=
# OCR_API_KEY=
# ANTHROPIC_API_KEY=your_anthropic_key_here
# MCP_IMAGE_EXTRACTOR_PATH=
