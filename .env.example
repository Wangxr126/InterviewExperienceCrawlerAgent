# ============================================================
# 面经 Agent 项目环境变量示例
# 复制为 .env 并填入真实配置：cp .env.example .env
# 注意：请勿将 .env 提交到 Git（已加入 .gitignore）
# ============================================================


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. 全局 LLM 配置
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# LLM_MODE 可选值：
#   local  — 使用本地 Ollama（无需 API Key，推荐开发/离线）
#   remote — 使用云端 API（火山引擎、OpenAI、DashScope 等）
#
LLM_MODE=local


# ── 1.1 本地配置（Ollama）────────────────────────────────────
LLM_LOCAL_PROVIDER=ollama
LLM_LOCAL_MODEL=qwen3:4b
LLM_LOCAL_API_KEY=ollama
LLM_LOCAL_BASE_URL=http://localhost:11434/v1
LLM_LOCAL_TIMEOUT=300


# ── 1.2 远程配置（云端 API）──────────────────────────────────
LLM_REMOTE_PROVIDER=volcengine
LLM_REMOTE_MODEL=your_model_id
LLM_REMOTE_API_KEY=your_api_key_here
LLM_REMOTE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_REMOTE_TIMEOUT=300


# ── 1.3 通用参数 ─────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# 启动时预热 LLM（解决冷启动首请求慢），默认 true
# LLM_WARMUP_ENABLED=true

# 仅题目提取时可设为 false，跳过 Embedding/OCR/Reranker 预热以加快启动
# WARMUP_EMBEDDING_RERANK_OCR=false

# Ollama 模型常驻显存：启动 Ollama 前设置 OLLAMA_KEEP_ALIVE=-1
#   Windows：运行 run_ollama.bat
#   Linux/Mac：OLLAMA_KEEP_ALIVE=-1 ollama serve 或运行 ./run_ollama.sh


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. 各 Agent 差异化配置（留空则使用全局 LLM 配置）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── 2.1 Knowledge Manager Agent（知识管理器）─────────────────
#
# ARCHITECT_MODE 可选值：local | remote（留空使用全局 LLM_MODE）
#
ARCHITECT_MODE=local
KNOWLEDGE_MANAGER_TEMPERATURE=0.2
KNOWLEDGE_MANAGER_MAX_TOKENS=


# ── 2.2 Interviewer Agent（面试官）────────────────────────────
#
# INTERVIEWER_MODE 可选值：local | remote（留空使用全局 LLM_MODE）
#
INTERVIEWER_MODE=local

INTERVIEWER_LOCAL_PROVIDER=ollama
INTERVIEWER_LOCAL_MODEL=qwen3:4b
INTERVIEWER_LOCAL_BASE_URL=http://localhost:11434/v1
INTERVIEWER_LOCAL_TIMEOUT=180

INTERVIEWER_REMOTE_PROVIDER=
INTERVIEWER_REMOTE_MODEL=
INTERVIEWER_REMOTE_BASE_URL=
INTERVIEWER_REMOTE_TIMEOUT=

INTERVIEWER_TEMPERATURE=0.5
INTERVIEWER_MAX_TOKENS=
INTERVIEWER_MAX_STEPS=20
INTERVIEWER_TIMEOUT=180


# ── 2.3 Miner Agent（题目提取器 / 信息挖掘师）─────────────────
#
# MINER_MODE 可选值：
#   local     — 本地单阶段（仅用 Stage1 模型）
#   remote    — 远程单阶段（仅用 Stage2/REMOTE 模型）
#   two_stage — 两阶段：Stage1 本地粗提取 + Stage2 豆包精加工（推荐）
#
MINER_MODE=two_stage


# Stage 1 本地模型（two_stage 时第一步用）
MINER_LOCAL_PROVIDER=ollama
MINER_LOCAL_MODEL=qwen3:4b
MINER_LOCAL_BASE_URL=http://localhost:11434/v1
MINER_LOCAL_TIMEOUT=180

MINER_REMOTE_PROVIDER=
MINER_REMOTE_MODEL=
MINER_REMOTE_API_KEY=
MINER_REMOTE_BASE_URL=
MINER_REMOTE_TIMEOUT=

MINER_TEMPERATURE=0
MINER_MAX_TOKENS=2048
MINER_MAX_STEPS=100
MINER_MAX_RETRIES=3

# Stage 2 豆包专用配置（two_stage 时精加工阶段）
# MINER_STAGE2_MODEL=doubao-1-5-pro-32k-250115
# MINER_STAGE2_API_KEY=your_volcengine_api_key
# MINER_STAGE2_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# MINER_STAGE2_MAX_TOKENS=131072
# MINER_STAGE2_TIMEOUT=300

# 备用模型（额度超限时按序切换），整行 JSON 勿换行
# MINER_STAGE2_FALLBACK_MODELS=[{"model":"xxx","api_key":"yyy","base_url":"https://..."}]


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. Embedding（向量化，用于 MemoryTool 语义记忆）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# EMBED_MODEL_TYPE 可选值：
#   ollama   — 本地 Ollama（需先 ollama pull qwen3-embedding:0.6b）
#   dashscope — 阿里云 DashScope（需 EMBED_API_KEY）
#
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v4
EMBED_API_KEY=your_dashscope_api_key_here
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 本地 Ollama
# EMBED_MODEL_TYPE=ollama
# EMBED_MODEL_NAME=qwen3-embedding:0.6b
# EMBED_OLLAMA_URL=http://localhost:11434


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3.5 检索与重排（RAG 检索后重排）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 需先 ollama pull dengcao/Qwen3-Reranker-8B:Q4_K_M
#
RERANK_ENABLED=true
RERANK_MODEL=dengcao/Qwen3-Reranker-8B:Q4_K_M
RERANK_OLLAMA_URL=http://localhost:11434
RERANK_TOP_N=5
RERANK_MAX_DOC_LENGTH=1024
RERANK_TIMEOUT=60

# 检索参数（向量检索 + 重排）
RETRIEVAL_SEARCH_TOP_K=15
RETRIEVAL_SCORE_THRESHOLD=0.5
RETRIEVAL_SIMILAR_LIMIT=5
RETRIEVAL_CHECK_DUPLICATE_THRESHOLD=0.92


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. Neo4j 知识图谱
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 本地 Docker 启动：docker compose up -d
# 管理界面：http://localhost:7474
#
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. Qdrant 向量数据库（hello-agents MemoryTool）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 本地 Docker：docker compose up -d qdrant → http://localhost:6333
# 云端：使用 QDRANT_URL + QDRANT_API_KEY
#
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. 本地存储（所有运行时文件统一在 backend/data 下）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
SQLITE_DB_PATH=./backend/data/local_data.db
MEMORY_DATA_DIR=./backend/data/memory
LOG_DIR=./backend/logs
XHS_USER_DATA_DIR=./backend/data/xhs_user_data
LLM_PROMPT_LOG_CSV=./微调/llm_logs/llm_prompt_log.jsonl


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6.5 爬虫来源（正文抓取）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# CRAWLER_SOURCE 可选值：
#   local — 本地后端爬虫（NowcoderCrawler、xhs_crawler）
#   mcp   — 远程 MCP Content Fetcher（Render/Smithery 部署）
#
CRAWLER_SOURCE=local

MCP_CONTENT_FETCHER_URL=https://mcp-content-fetcher.onrender.com
MCP_CONTENT_FETCHER_TIMEOUT=30

# Smithery 网关鉴权（通过 Smithery 访问 MCP 时使用）
# SMITHERY_API_KEY=


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 7. 牛客网爬虫
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Cookie 获取：浏览器登录牛客 → F12 → Network → 任意请求 → Request Headers → Cookie
#
NOWCODER_COOKIE=
NOWCODER_KEYWORDS=agent面经
NOWCODER_MAX_PAGES=2


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 8. 小红书爬虫
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
XHS_KEYWORDS=agent面经
XHS_MAX_NOTES_PER_KEYWORD=5
XHS_LOGIN_WAIT_SECONDS=120


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 9. 爬虫重试与批处理
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 牛客详情页抓取失败时的重试
CRAWLER_FETCH_MAX_RETRIES=3
CRAWLER_RETRY_DELAY=5

# 爬取+提取失败任务的最大递归重试次数
CRAWLER_RECURSIVE_RETRY_MAX=10


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 10. 微调辅助大模型（微调页面生成标注数据）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
FINETUNE_LLM_PROVIDER=volcengine
FINETUNE_LLM_MODEL=your_model_id
FINETUNE_LLM_API_KEY=your_api_key_here
FINETUNE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
FINETUNE_LLM_TEMPERATURE=0.2
FINETUNE_LLM_TIMEOUT=180


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 11. 定时调度器
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
SCHEDULER_ENABLE_NOWCODER=true
SCHEDULER_NOWCODER_HOURS=2,14

SCHEDULER_ENABLE_XHS=true

# 任务处理器 cron 分钟，"0" 表示每小时整点
SCHEDULER_PROCESS_MINUTE=0

# 任务队列每批处理条数（定时任务、API 默认值均由此读取）
CRAWLER_PROCESS_BATCH_SIZE=100


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 12. 对话型 Agent（默认用户与 Interviewer）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
DEFAULT_USER_ID=default_user
INTERVIEWER_MAX_STEPS=100


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 13. OCR 配置（帖子内图片文字识别）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# OCR_METHOD 可选值：
#   ollama_vl     — 本地 Ollama 视觉模型（推荐，无需 API Key）
#   qwen_vl       — 阿里云百炼 Qwen-VL（复用 EMBED_API_KEY）
#   claude_vision — Anthropic Claude Vision（需 ANTHROPIC_API_KEY）
#   mcp           — 本地 mcp-image-extractor（Node.js，已安装在 mcp/ 目录）
#
OCR_METHOD=ollama_vl

# OCR 模型名（留空则自动选默认）
#   ollama_vl 默认：qwen3-vl:2b
#   qwen_vl 默认：qwen-vl-plus
#   claude_vision 默认：claude-3-5-sonnet-20241022
# OCR_MODEL=qwen3-vl:2b

# OCR 单张超时（秒），图片多或模型慢时可调大
# OCR_TIMEOUT=120

# 单张失败/乱码时重试次数
# OCR_RETRIES=3

# OCR API Key（qwen_vl 留空则复用 EMBED_API_KEY）
# OCR_API_KEY=

# mcp-image-extractor 路径（OCR_METHOD=mcp 时使用，留空则自动定位）
# MCP_IMAGE_EXTRACTOR_PATH=

# Anthropic API Key（OCR_METHOD=claude_vision 时使用）
# 获取方式：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 14. 其他（语音转文字等）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 关闭 Windows 下 HuggingFace symlink 警告
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# SiliconFlow API Key（MCP speech-to-text 等可能使用）
# SILICONFLOW_API_KEY=
